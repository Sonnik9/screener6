{
  "_workflow": {
    "mode": "v12: Benchmark Auto-tune + Modular Filters + Penalty Counter"
  },
  "app": {
    "quote": "USDT",
    "max_symbols": 0,
    "concurrent_symbols": 5,
    "top_n": 10,
    "request_interval_ms": 150,
    "scan_interval_sec": 600,
    "screen_once": true,
    "is_click": true
  },
  "benchmark": {
    "enable": false,
    "target_symbol": "ZIGUSDTM",
    "lookback_candles": 60,
    "cache_file": "benchmark_cache.json"
  },
  "filter": {
    "timeframe": "1m",
    "lookback_candles": 30,
    "daily_volume": {
      "enable": true,
      "min_usdt": 500000.0,
      "max_usdt": 7000000.0
    },
    "donchian": {
      "enable": true,
      "min_pct": 1.0,
      "max_pct": 7.0
    },
    "wicks": {
      "enable": true,
      "ratio_threshold": 3.0,
      "min_valid_pct": 50.0
    },
    "narrow_penalty": {
      "enable": true,
      "min_range_pct": 0.15,
      "max_penalty_pct": 25.0
    }
  }
}