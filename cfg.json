{
  "_workflow": {
    "mode": "v12: Historical Benchmark + Independent Penalty + Doji Math"
  },
  "app": {
    "quote": "USDT",
    "max_symbols": 0,
    "concurrent_symbols": 5,
    "top_n": 10,
    "request_interval_ms": 150,
    "scan_interval_sec": 600,
    "screen_once": true,
    "is_click": true
  },
  "benchmark": {
    "enable": false,
    "target_symbol": "WILDUSDTM",
    "start_time": "2026-02-24 21:04:00",
    "end_time": "2026-02-24 22:04:00",
    "cache_file": "benchmark_cache.json"
  },
"filter": {
    "timeframe": "1m",
    "lookback_candles": 30,
    "daily_volume": {
      "enable": true,
      "min_usdt": 500000.0,
      "max_usdt": 10000000.0
    },
    "donchian": {
      "enable": true,
      "min_pct": 2.0,
      "max_pct": 10.0,
      "max_drift_pct": 1.5
    },
    "atr": {
      "enable": true,
      "period": 14,
      "min_pct": 1.5,
      "max_pct": 15.0
    },
    "wicks": {
      "enable": true,
      "ratio_threshold": 2.5,
      "candle_range_min_pct": 1.0, 
      "min_valid_pct": 50.0         
    },
    "narrow_penalty": {
      "enable": true,
      "min_range_pct": 0.2,
      "max_penalty_pct": 20.0
